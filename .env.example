# Render backend URL (no trailing slash)
VITE_API_URL=https://concordia-backend-web.onrender.com

# Web push (optional — order status notifications in the browser)
# Generate keys: cd Concordia-Backend && npx web-push generate-vapid-keys
# Set the public key here (Vercel → Environment Variables) and both keys on Render.
# VITE_VAPID_PUBLIC_KEY=
