# Backend API — required for WebSocket and non-proxied builds.
# On concordiapizza.de, HTTP /api is proxied via vercel.json to Render; sockets must connect directly.
VITE_API_URL=https://api.concordiapizza.de

# Website pre-launch gate (Vercel sets false in vercel.json). Native app always skips this screen.
# VITE_COMING_SOON=false

# Optional override for Socket.IO (defaults to VITE_API_URL)
# VITE_SOCKET_URL=https://api.concordiapizza.de

# Vercel rewrites in vercel.json point /api/* to the Render backend above.

# Web push — browser offer/order notifications (must match backend VAPID_PUBLIC_KEY)
# Generate keys on backend: npx web-push generate-vapid-keys
# VITE_VAPID_PUBLIC_KEY=
