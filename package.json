{
  "name": "concordia-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-crawl-menus.mjs && vite build",
    "build:cap": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "lint": "eslint .",
    "i18n:sync": "node scripts/sync-locales.mjs",
    "i18n:sync-missing": "node scripts/sync-missing-locales.mjs",
    "assets:compress": "node scripts/compress-static-assets.mjs",
    "cap:sync": "npm run build:cap && npx cap sync",
    "cap:sync:ios": "npm run build:cap && npx cap sync ios",
    "cap:sync:android": "npm run build:cap && npx cap sync android",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "apk:debug": "npm run cap:sync:android && cd android && .\\gradlew.bat assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.7",
    "@capacitor/app": "^7.1.2",
    "@capacitor/core": "^7.6.7",
    "@capacitor/ios": "^7.6.7",
    "@capacitor/splash-screen": "^7.0.5",
    "@capacitor/status-bar": "^7.0.6",
    "@paypal/react-paypal-js": "^10.0.0",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.8.0",
    "@tanstack/react-query": "^5.100.10",
    "axios": "^1.16.0",
    "chart.js": "^4.5.1",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "leaflet": "^1.9.4",
    "react": "^19.2.6",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-qr-scanner": "^1.0.0-alpha.11",
    "react-router-dom": "^7.15.0",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.7",
    "@eslint/js": "^10.0.1",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "sharp": "^0.35.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.12"
  }
}
